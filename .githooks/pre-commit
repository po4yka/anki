#!/usr/bin/env bash
# Pre-commit hook: runs formatting, linting, and security checks.
# Install: git config core.hooksPath .githooks
# Bypass: SKIP_HOOKS=1 git commit -m "..."

set -euo pipefail

if [ "${SKIP_HOOKS:-0}" = "1" ]; then
    echo "[pre-commit] SKIP_HOOKS=1 -- skipping all checks"
    exit 0
fi

echo "[pre-commit] Running cargo fmt check..."
cargo fmt --all -- --check || {
    echo "[pre-commit] cargo fmt failed. Run 'cargo fmt --all' to fix."
    exit 1
}

echo "[pre-commit] Running cargo clippy..."
cargo clippy --workspace -- -D warnings || {
    echo "[pre-commit] cargo clippy failed. Fix warnings before committing."
    exit 1
}

echo "[pre-commit] Running cargo deny check advisories..."
if command -v cargo-deny &>/dev/null || cargo deny --version &>/dev/null 2>&1; then
    cargo deny check advisories || echo "[pre-commit] cargo deny found advisories (non-blocking)"
else
    echo "[pre-commit] cargo deny not installed, skipping advisory check"
fi

if command -v swiftlint &>/dev/null; then
    echo "[pre-commit] Running swiftlint --strict..."
    swiftlint --strict || {
        echo "[pre-commit] swiftlint failed."
        exit 1
    }
fi

if command -v swiftformat &>/dev/null; then
    echo "[pre-commit] Running swiftformat --lint..."
    swiftformat --lint . || {
        echo "[pre-commit] swiftformat lint failed."
        exit 1
    }
fi

# Optional: check Swift-Rust type sync
# ./scripts/check-swift-types.sh

echo "[pre-commit] All checks passed."
